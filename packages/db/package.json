{
  "name": "@whistle/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "prisma generate --schema=prisma/schema.prisma && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "seed": "tsx scripts/seed-agents.ts",
    "seed:matches": "tsx scripts/seed-matches.ts",
    "seed:players": "tsx scripts/seed-players.ts",
    "seed:scoring": "tsx scripts/seed-scoring.ts",
    "enrich:photos": "tsx scripts/enrich-photos.ts"
  },
  "dependencies": {
    "@prisma/client": "6.3.0",
    "@whistle/scoring": "workspace:*"
  },
  "devDependencies": {
    "prisma": "6.3.0",
    "tsx": "4.19.2",
    "typescript": "5.8.2",
    "vitest": "3.0.5"
  }
}
